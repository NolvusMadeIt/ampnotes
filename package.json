{
  "name": "ampnotes",
  "version": "0.1.6",
  "description": "AMP, All My Prompts: a desktop-first prompt notebook for writing, validating, sharing, and extending prompts.",
  "main": "out/main/index.js",
  "author": "NolvusMadeIt",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "postinstall": "electron-builder install-app-deps && npm run rebuild:native",
    "dev": "npm run rebuild:native && electron-vite dev",
    "dev:electron": "npm run rebuild:native && electron-vite dev",
    "build": "npm run rebuild:native && electron-vite build",
    "pack:win": "npm run build && electron-builder install-app-deps && electron-builder --win nsis --x64",
    "dist": "npm run pack:win",
    "preview": "electron-vite preview",
    "rebuild:native": "electron-rebuild -f",
    "rebuild:node": "npm rebuild better-sqlite3",
    "typecheck": "tsc --noEmit",
    "test": "npm run rebuild:node && vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "keytar": "^7.9.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "uuid": "^13.0.0",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.9.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^31.7.7",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "jsdom": "^27.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.ampnotes.desktop",
    "productName": "AMP",
    "files": [
      "out/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "src/assets/imgs/icon.ico",
        "to": "icon.ico"
      }
    ],
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "src/assets/imgs/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AMP"
    },
    "artifactName": "AMP-Setup-${version}.${ext}",
    "publish": {
      "provider": "github",
      "owner": "NolvusMadeIt",
      "repo": "ampnotes"
    }
  }
}
